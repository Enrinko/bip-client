# --- Build artifacts ---
target/
dist/

# --- jpackage / native installers (build output, never source) ---
*.exe
*.msi
*.dmg
*.pkg

# --- IDE ---
.idea/
*.iml
*.iws
*.ipr
.vscode/

# --- OS ---
.DS_Store
Thumbs.db

# --- Local teaching-load data: spreadsheets may contain personal data, keep them out of VCS ---
*.xlsx
*.xls

# --- Secrets: never commit real env / keys ---
.env
.env.*
!.env.example
*.pem
*.key
*credentials*
